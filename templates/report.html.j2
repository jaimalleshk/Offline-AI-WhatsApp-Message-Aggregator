<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ title }}</title>
<style>
  @page { size: A4; margin: 0; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  :root{
    --ink:#16202b; --muted:#55636f; --soft:#7c8b97; --line:#e3e8ee; --bg:#f5f8fa;
    --brand:#0d4250; --brand2:#15728a; --accent:#e08a1e;
    --blue:#dbeafe; --purple:#ede9fe; --teal:#ccfbf1; --green:#dcfce7;
    --amber:#fef3c7; --orange:#ffedd5; --coral:#fee2e2; --gray:#eef1f4;
  }
  html,body{ background:#fff; }
  body{ font-family:"Segoe UI",-apple-system,Roboto,Helvetica,Arial,sans-serif;
        color:var(--ink); font-size:12.5px; line-height:1.5;
        -webkit-print-color-adjust:exact; print-color-adjust:exact; }
  @media screen{
    body{ background:#e7ecf0; }
    .page{ width:210mm; margin:16px auto; background:#fff; box-shadow:0 3px 22px rgba(0,0,0,.14); }
  }
  @media print{ .page{ width:auto; margin:0; box-shadow:none; } }

  .hdr{ background:linear-gradient(110deg,#0a3a47,#15728a 60%,#1a8aa6); color:#fff;
        padding:20px 14mm 16px; display:flex; align-items:center; gap:14px; }
  .hdr .circle{ width:50px; height:50px; border-radius:50%; background:rgba(255,255,255,.18);
        border:1px solid rgba(255,255,255,.35); display:flex; align-items:center;
        justify-content:center; font-weight:800; font-size:16px; flex-shrink:0; }
  .hdr h1{ font-size:27px; font-weight:800; letter-spacing:-.4px; line-height:1.05; }
  .hdr .sub{ font-size:13px; color:#cdeaf2; margin-top:3px; }

  .meta{ background:#0e2e38; color:#dbeef4; padding:9px 14mm; font-size:11px;
         display:flex; flex-wrap:wrap; gap:4px 24px; }
  .meta b{ color:#fff; }
  .crit{ background:#fbf6ec; border-bottom:1px solid #f0e6d2; padding:9px 14mm; font-size:11px; color:#6b5836; }
  .crit b{ color:var(--accent); text-transform:uppercase; letter-spacing:.4px; font-size:9.5px; }
  .crit ul{ margin:4px 0 0 16px; } .crit li{ margin:1px 0; }

  .wrap{ padding:15px 14mm 22px; }
  h2.sec{ font-size:16px; font-weight:800; color:var(--brand); margin:22px 0 10px;
          text-transform:uppercase; letter-spacing:.5px; padding-bottom:5px; border-bottom:2.5px solid var(--accent); }
  h2.sec:first-child{ margin-top:2px; }

  .kpis{ display:grid; grid-template-columns:repeat(6,1fr); gap:9px; }
  .kpi{ background:var(--bg); border:1px solid var(--line); border-radius:6px; padding:10px; text-align:center; }
  .kpi .v{ font-size:23px; font-weight:800; color:var(--brand); line-height:1; }
  .kpi .l{ font-size:8.8px; color:var(--soft); text-transform:uppercase; letter-spacing:.3px; margin-top:4px; }

  .lead{ font-size:13px; line-height:1.6; color:#26323d; background:var(--bg);
         border-left:4px solid var(--accent); padding:12px 15px; border-radius:0 6px 6px 0; }

  .disc{ border:1px solid var(--line); border-radius:7px; padding:11px 13px; margin-bottom:10px; break-inside:avoid; }
  .disc .top{ display:flex; justify-content:space-between; align-items:flex-start; gap:10px; }
  .disc .t{ font-size:13.5px; font-weight:700; color:var(--ink); }
  .disc .s{ font-size:12px; color:#36434f; margin:5px 0 6px; line-height:1.55; }
  .disc .who{ font-size:10.5px; color:var(--muted); }
  .disc .who b{ color:var(--brand); }
  .disc .links a{ font-size:10px; color:var(--brand2); word-break:break-all; }
  .badge{ display:inline-block; padding:2px 9px; border-radius:10px; font-size:9px; font-weight:700;
          text-transform:uppercase; letter-spacing:.3px; color:#3a4654; white-space:nowrap; }
  .b-blue{background:var(--blue)} .b-purple{background:var(--purple)} .b-teal{background:var(--teal)}
  .b-green{background:var(--green)} .b-amber{background:var(--amber)} .b-orange{background:var(--orange)}
  .b-gray{background:var(--gray)}
  .pill-grp{ display:inline-block; background:#eef4f6; color:#456; border-radius:9px;
             padding:1px 7px; font-size:9px; margin:1px 2px 0 0; }

  .ev{ display:flex; gap:12px; border:1px solid var(--line); border-radius:7px; padding:10px 12px;
       margin-bottom:9px; break-inside:avoid; }
  .ev .date{ min-width:50px; height:50px; border-radius:8px; background:var(--brand); color:#fff;
       display:flex; flex-direction:column; align-items:center; justify-content:center; flex-shrink:0; }
  .ev .date.gray{background:#9aa7b2} .ev .date.green{background:#059669} .ev .date.amber{background:#d97706}
  .ev .date.teal{background:#0d9488} .ev .date.orange{background:#ea580c} .ev .date.coral{background:#dc2626}
  .ev .date .n{ font-size:15px; font-weight:800; line-height:1; }
  .ev .date .m{ font-size:8px; font-weight:700; text-transform:uppercase; margin-top:2px; opacity:.85; }
  .ev .et{ font-size:13px; font-weight:700; }
  .ev .er{ font-size:11px; color:var(--muted); margin-top:2px; }
  .ev .er b{ color:#3a4654; }
  .ev a{ color:var(--brand2); word-break:break-all; }
  .ev .st{ font-size:8.5px; font-weight:700; text-transform:uppercase; color:var(--soft); }

  table{ width:100%; border-collapse:collapse; font-size:11.5px; }
  th{ text-align:left; color:var(--soft); font-size:9.5px; text-transform:uppercase; letter-spacing:.3px;
      border-bottom:2px solid var(--line); padding:6px 8px; }
  td{ padding:5px 8px; border-bottom:1px solid #eef2f6; }
  .note{ font-size:11px; color:var(--muted); background:var(--bg); border-radius:6px; padding:9px 12px; }
  .footer{ margin-top:22px; padding-top:10px; border-top:1px solid var(--line);
           font-size:9.3px; color:var(--soft); line-height:1.55; }
  .sub2{ font-size:10.5px; color:var(--soft); margin:-5px 0 9px; }
</style>
</head>
<body>
<div class="page">

  <div class="hdr">
    <div class="circle">{{ org_initials }}</div>
    <div>
      <h1>{{ title }}</h1>
      <div class="sub">{{ subtitle }} &nbsp;·&nbsp; {{ window_start }} – {{ window_end }} ({{ period_days }} days)</div>
    </div>
  </div>

  <div class="meta">
    <span><b>Period:</b> {{ window_start }} → {{ window_end }}</span>
    <span><b>Groups:</b> {{ stats.groups_count }}</span>
    <span><b>Generated:</b> {{ generated }}</span>
    <span><b>Processed:</b> fully offline (local AI)</span>
  </div>

  {% if criteria %}
  <div class="crit">
    <b>Extraction criteria</b>
    <ul>{% for c in criteria %}<li>{{ c }}</li>{% endfor %}</ul>
  </div>
  {% endif %}

  <div class="wrap">

    <h2 class="sec">At a Glance</h2>
    <div class="kpis">
      {% for k in kpis %}<div class="kpi"><div class="v">{{ k.v }}</div><div class="l">{{ k.l }}</div></div>{% endfor %}
    </div>
    {% if dedup.cross_group_duplicate_topics %}
    <p class="sub2" style="margin-top:8px">{{ dedup.duplicate_copies_removed }} duplicate copies removed;
      {{ dedup.cross_group_duplicate_topics }} topics appeared in more than one group (counted once).</p>
    {% endif %}

    {% if highlights %}
    <h2 class="sec">Top Highlights</h2>
    <div class="lead">{{ highlights }}</div>
    {% endif %}

    <h2 class="sec">Unique Discussions ({{ discussions|length }})</h2>
    <p class="sub2">Distinct topics across all groups, with who took part. Most-discussed first.</p>
    {% for d in discussions %}
    <div class="disc">
      <div class="top">
        <div class="t">{{ d.topic }}</div>
        <span class="badge b-{{ d.color }}">{{ d.category }}</span>
      </div>
      {% if d.summary %}<div class="s">{{ d.summary }}</div>{% endif %}
      <div class="who"><b>{{ d.participant_count }}</b> participant{{ 's' if d.participant_count != 1 else '' }}{% if d.participants %}: {{ d.participants|join(', ') }}{% endif %}
        &nbsp;·&nbsp; {{ d.message_count }} message{{ 's' if d.message_count != 1 else '' }}
        {% if d.groups %}&nbsp;·&nbsp; {% for g in d.groups %}<span class="pill-grp">{{ g[:26] }}</span>{% endfor %}{% endif %}
      </div>
      {% if d.links %}<div class="links">{% for l in d.links %}<a href="{{ l }}">{{ l }}</a>{% if not loop.last %} · {% endif %}{% endfor %}</div>{% endif %}
    </div>
    {% else %}
    <p class="note">No substantive discussions detected in this period.</p>
    {% endfor %}

    <h2 class="sec">Events ({{ event_total }})</h2>
    <p class="sub2">Upcoming first; past events last. Logistics captured where stated.</p>
    {% for e in events %}
    <div class="ev">
      <div class="date {{ e.badge_cls }}"><div class="n">{{ e.badge.num }}</div><div class="m">{{ e.badge.mon }}</div></div>
      <div style="flex:1; min-width:0">
        <div class="et">{{ e.title }} <span class="st">· {{ e.status }}</span></div>
        <div class="er">
          {% if e.date %}<b>Date:</b> {{ e.date }}&nbsp; {% endif %}
          {% if e.time %}<b>Time:</b> {{ e.time }}&nbsp; {% endif %}
          {% if e.venue %}<b>Venue:</b> {{ e.venue }}&nbsp; {% endif %}
          {% if e.location %}<b>Location:</b> {{ e.location }}&nbsp; {% endif %}
          {% if e.host %}<b>Host:</b> {{ e.host }}&nbsp; {% endif %}
          {% if e.contact %}<b>Contact:</b> {{ e.contact }}&nbsp; {% endif %}
          <span class="pill-grp">{{ e.group[:26] }}</span>
        </div>
        {% if e.conference_link or e.registration_link %}
        <div class="er">
          {% if e.conference_link %}<b>Join:</b> <a href="{{ e.conference_link }}">{{ e.conference_link }}</a>&nbsp; {% endif %}
          {% if e.registration_link %}<b>Register:</b> <a href="{{ e.registration_link }}">{{ e.registration_link }}</a>{% endif %}
        </div>
        {% endif %}
      </div>
    </div>
    {% else %}
    <p class="note">No events detected in this period.</p>
    {% endfor %}

    {% if low_activity %}
    <p class="sub2" style="margin-top:10px"><b>Low-activity chats</b> (below threshold, not summarised):
      {% for g in low_activity %}{{ g.group[:30] }} ({{ g.messages }}){% if not loop.last %}, {% endif %}{% endfor %}.</p>
    {% endif %}

    {% if pleasantries.count %}
    <h2 class="sec">Greetings &amp; Wishes ({{ pleasantries.count }})</h2>
    <p class="sub2">Birthdays, thanks, blessings and congratulations — grouped here for completeness.</p>
    <table>
      <thead><tr><th>Type</th><th style="text-align:right">Count</th></tr></thead>
      <tbody>
      {% for t, n in pleasantries.by_type.items() %}<tr><td>{{ t|title }}</td><td style="text-align:right">{{ n }}</td></tr>{% endfor %}
      </tbody>
    </table>
    {% if pleasantries.top_people %}
    <p class="sub2" style="margin-top:7px">Most active in greetings:
      {% for name, n in pleasantries.top_people %}{{ name }} ({{ n }}){% if not loop.last %}, {% endif %}{% endfor %}.</p>
    {% endif %}
    {% endif %}

    <div class="footer">
      <b>Methodology.</b> Messages were collected from the WhatsApp groups/chats you selected and processed
      entirely on-device. System notices were removed; greetings/thanks/birthday wishes were routed to the
      "Greetings &amp; Wishes" section. Cross-group duplicates were merged via local semantic embeddings
      (nomic-embed-text). Discussions, events and the digest were produced by a local
      <b>{{ cfg.models.analysis }}</b> model; event posters were read with Tesseract OCR + a local vision model.
      No data left this machine and no cloud AI was used. Extracted facts come only from the messages —
      verify event logistics before relying on them.
    </div>

  </div><!-- /.wrap -->
</div><!-- /.page -->
</body>
</html>
